    "date-fns": "^3.0.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.12.0",
    "lenis": "^1.3.20",
    "lucide-react": "^0.400.0",
    "next": "^15.5.14",
    "next-sitemap": "^4.2.0",
    "plaiceholder": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.2.4",
    "react-countup": "^6.5.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
