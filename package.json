{
  "name": "vivabem-saude",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "dev": "vinext dev",
    "build": "vinext build && node -e \"require('fs').mkdirSync('.next', {recursive:true})\"",
    "start": "vinext start",
    "typegen": "vinext typegen",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "npm run typegen && tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "analyze": "cross-env ANALYZE=true vinext build"
  },
  "dependencies": {
    "@gsap/react": "^2.1.0",
    "@hookform/resolvers": "^3.3.0",
    "@next/bundle-analyzer": "^14.2.35",
